{
	"$schema": "https://biomejs.dev/schemas/2.3.10/schema.json",
	"javascript": {
		"formatter": {
			"indentStyle": "space",
			"quoteStyle": "single",
			"jsxQuoteStyle": "single"
		}
	},
	"formatter": {
		"enabled": true
	},
	"linter": {
		"rules": {
			"suspicious": {
				"noExplicitAny": "warn",
				"noArrayIndexKey": "off"
			}
		}
	},
	"assist": { "actions": { "source": { "organizeImports": "on" } } }
}
